server {
  listen ${PORT} default_server;
  listen [::]:${PORT} default_server;
  server_name _;

  root /usr/share/nginx/html;
  index index.html;

  location /health {
    access_log off;
    add_header Content-Type text/plain;
    return 200 "ok\n";
  }

  location / {
    try_files $uri $uri/ /index.html;
  }
}
